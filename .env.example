# Copy this file to .env and fill in your values.
# Only fill in the key for the provider you want to use.
# Ollama needs no key at all — it runs fully local.

# Choose your provider: ollama | openai | openrouter | anthropic
LLM_PROVIDER=ollama
LLM_API_KEY=your_api_key_here
LLM_MODEL=your_model_here

# Provider-specific keys (only the one you use)
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENROUTER_API_KEY=your_openrouter_key_here

# Optional model overrides
# OLLAMA_MODEL=llama3.2
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Paths (no need to change unless using Docker)
# DB_PATH=./minrag.db
# PDF_DIR=./pdfs
